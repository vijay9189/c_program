#include<stdio.h>
int main(void){
    int a=5;
    float b=5.5;
    int *p1=&a;
    float *p2=&b;
    
    printf("value of p1 =  addres of a = %p\n",p1);
    printf("value of p2 = adress of b = %p\n",p2);
    printf("address of p1 = %p\n",&p1);
    printf("address of p2 = %p\n",&p2);
    printf("values of a =%d %d %d \n ", a,*p1,*(&a));
    printf("values of b = %.1f %.1f %.1f\n", b,*p2,*(&b));
    return 0;
    
}


